  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login – Admin",
          "event": [{ "listen": "test", "script": { "exec": ["var r=pm.response.json();if(r.token){pm.collectionVariables.set('token',r.token);console.log('Admin token set');}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/login",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}" }
          }
        },
        {
          "name": "Login – Field User",
          "event": [{ "listen": "test", "script": { "exec": ["var r=pm.response.json();if(r.token){pm.collectionVariables.set('field_token',r.token);console.log('Field token set');}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ama.bdm.chandigarh@alembic.co.in\",\n  \"sap_code\": \"111367\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Admin – Dashboard & Calendar",
      "item": [
        {
          "name": "Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/hospitalcare/calendar/automation/admin/dashboard?month=5&year=2025", "host": ["{{base_url}}"], "path": ["hospitalcare","calendar","automation","admin","dashboard"], "query": [{ "key": "month", "value": "5" }, { "key": "year", "value": "2025" }] }
          }
        },
        {
          "name": "Calendar View",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/hospitalcare/calendar/automation/admin/calendar?month=5&year=2025", "host": ["{{base_url}}"], "path": ["hospitalcare","calendar","automation","admin","calendar"], "query": [{ "key": "month", "value": "5" }, { "key": "year", "value": "2025" }] }
          }
        }
      ]
    },
    {
      "name": "Admin – Events",
      "item": [
        {
          "name": "List All Events",

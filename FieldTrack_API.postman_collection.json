          "name": "Add Event – Quarterly (KAM only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/admin/events",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"KAM Quarterly Review\",\n  \"description\": \"Quarterly review submission for KAM (AM level)\",\n  \"type\": \"quarterly\",\n  \"date\": null,\n  \"assigned_to\": \"KAM\",\n  \"seven_day_reminder\": false\n}" }
          }
        },
        {
          "name": "Add Event – Half-Yearly (RM)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/admin/events",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"RM Regional Report\",\n  \"description\": \"Half-yearly regional performance report for RMs\",\n  \"type\": \"half-yearly\",\n  \"date\": null,\n  \"assigned_to\": \"RM\",\n  \"seven_day_reminder\": false\n}" }
          }

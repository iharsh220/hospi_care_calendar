{
  "info": {
    "_postman_id": "fieldtrack-2025",
    "name": "FieldTrack API",
    "description": "FieldTrack – Hospital Care Calendar Automation. Base URL: {{base_url}}/hospitalcare/calendar/automation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"

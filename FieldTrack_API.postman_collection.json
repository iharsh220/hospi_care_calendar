          "name": "Add Event – Yearly / Specific Date (All)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/admin/events",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Annual Compliance Audit\",\n  \"description\": \"Mandatory yearly compliance audit for all field users\",\n  \"type\": \"yearly\",\n  \"date\": \"2025-12-15\",\n  \"assigned_to\": \"all\",\n  \"seven_day_reminder\": true\n}" }
          }
        },
        {
          "name": "Edit Event",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/admin/events/1",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Safety Inspection\",\n  \"description\": \"Updated description\",\n  \"type\": \"monthly\",\n  \"date\": null,\n  \"assigned_to\": \"all\",\n  \"seven_day_reminder\": false\n}" }
          }
        },
        {
          "name": "Delete (Deactivate) Event",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/admin/events/1"
          }
        }
      ]
    },
    {
      "name": "Admin – Tracking & Users",
      "item": [
        {
          "name": "Tracking – All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/hospitalcare/calendar/automation/admin/tracking?month=5&year=2025&search=&filter=all&region=all", "host": ["{{base_url}}"], "path": ["hospitalcare","calendar","automation","admin","tracking"], "query": [{ "key": "month", "value": "5" }, { "key": "year", "value": "2025" }, { "key": "search", "value": "" }, { "key": "filter", "value": "all" }, { "key": "region", "value": "all" }] }
          }
        },
        {
          "name": "Tracking – Filter: Carry Forwards",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/hospitalcare/calendar/automation/admin/tracking?month=5&year=2025&filter=carry&region=all", "host": ["{{base_url}}"], "path": ["hospitalcare","calendar","automation","admin","tracking"], "query": [{ "key": "month", "value": "5" }, { "key": "year", "value": "2025" }, { "key": "filter", "value": "carry" }, { "key": "region", "value": "all" }] }
          }
        },

            "url": { "raw": "{{base_url}}/hospitalcare/calendar/automation/admin/incomplete?month=5&year=2025&filter=all", "host": ["{{base_url}}"], "path": ["hospitalcare","calendar","automation","admin","incomplete"], "query": [{ "key": "month", "value": "5" }, { "key": "year", "value": "2025" }, { "key": "filter", "value": "all" }] }
          }
        },
        {
          "name": "Field Users Directory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/hospitalcare/calendar/automation/admin/users?search=&region=all", "host": ["{{base_url}}"], "path": ["hospitalcare","calendar","automation","admin","users"], "query": [{ "key": "search", "value": "" }, { "key": "region", "value": "all" }] }
          }
        },
        {
        "name": "Add Field User",
        "request": {
          "method": "POST",
          "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],

            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/admin/events",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Safety Inspection\",\n  \"description\": \"Monthly safety check for all field users\",\n  \"type\": \"monthly\",\n  \"date\": null,\n  \"assigned_to\": \"all\",\n  \"seven_day_reminder\": false\n}" }
          }
        },

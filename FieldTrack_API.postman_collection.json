    ]
  },
    {
      "name": "Field User",
      "item": [
        {
          "name": "My Events (Current Month)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{field_token}}" }],
            "url": { "raw": "{{base_url}}/hospitalcare/calendar/automation/field/my-events?month=5&year=2025", "host": ["{{base_url}}"], "path": ["hospitalcare","calendar","automation","field","my-events"], "query": [{ "key": "month", "value": "5" }, { "key": "year", "value": "2025" }] }
          }
        },
        {
          "name": "Submit Event Completion (with proof)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{field_token}}" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/field/complete",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "event_id", "value": "1", "type": "text", "description": "Assignment ID from my-events response" },
                { "key": "completed_on", "value": "2025-05-20", "type": "text" },
                { "key": "notes", "value": "Completed successfully", "type": "text" },
                { "key": "proof_image", "type": "file", "src": "", "description": "Upload JPG/PNG/PDF file" }
              ]
            }
          }
        },
        {
          "name": "My History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{field_token}}" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/field/my-history"
          }
        },
        {
          "name": "Team Tracking (ZM/RM/AM hierarchy view)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{field_token}}" }],
            "url": { "raw": "{{base_url}}/hospitalcare/calendar/automation/field/team-tracking?month=5&year=2025", "host": ["{{base_url}}"], "path": ["hospitalcare","calendar","automation","field","team-tracking"], "query": [{ "key": "month", "value": "5" }, { "key": "year", "value": "2025" }] }
          }
        }
      ]
    },
    {

          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/hospitalcare/calendar/automation/admin/events",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"BDM Activity Report\",\n  \"description\": \"Bi-monthly activity submission for BDM level\",\n  \"type\": \"bi-monthly\",\n  \"date\": null,\n  \"assigned_to\": \"BDM\",\n  \"seven_day_reminder\": false\n}" }
          }
        },
